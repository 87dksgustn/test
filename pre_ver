# ============================================================
# Placeholder surrogate engine
# Replace this part with real trained model later.
# ============================================================
class SurrogateEngine:
    def __init__(self, time_points: int = DEFAULT_TIME_POINTS):
        self.time_points = time_points
        self.output_names = [
            "Tmax_peak",
            "t_peak",
            "cooling_rate",
            "safety_score",
            "mass_proxy",
        ]

    def _normalize(self, value: float, lo: float, hi: float) -> float:
        if hi <= lo:
            return 0.0
        return (value - lo) / (hi - lo)

    def predict_curve(self, params: Dict[str, float], specs: List[ParameterSpec]) -> Tuple[np.ndarray, np.ndarray]:
        # Synthetic curve generator for a maximum-temperature time series.
        # This is only a placeholder shaped by the parameter values.
        t = np.linspace(0, 1200, self.time_points)

        spec_map = {s.name: s for s in specs}
        norm = {}
        for k, v in params.items():
            s = spec_map[k]
            norm[k] = self._normalize(v, s.lower, s.upper)

        p = list(norm.values())
        while len(p) < 8:
            p.append(0.5)

        base = 25.0
        rise_amp = 120 + 80 * p[0] - 40 * p[1] + 35 * p[2]
        peak_time = 180 + 500 * p[3]
        width = 60 + 180 * p[4]
        cooldown_strength = 0.015 + 0.05 * p[5]
        oscillation = 1.5 + 5.0 * p[6]
        late_heating = 20 * p[7]

        gaussian_peak = rise_amp * np.exp(-((t - peak_time) ** 2) / (2 * width ** 2))
        late_term = late_heating * (1 - np.exp(-np.maximum(t - peak_time, 0) / 250.0))
        cooldown = np.where(t > peak_time, np.exp(-cooldown_strength * (t - peak_time)), 1.0)
        wave = oscillation * np.sin(t / (45 + 25 * p[1]))

        curve = base + gaussian_peak * cooldown + late_term + wave
        curve = np.maximum(curve, 20)
        return t, curve

    def predict_field_points(
        self,
        params: Dict[str, float],
        specs: List[ParameterSpec],
        n_points: int = 150,
    ) -> np.ndarray:
        # Placeholder xyz points with a scalar severity value.
        # Intended to represent spatial output when true location-aware data becomes available.
        rng = np.random.default_rng(abs(hash(tuple(sorted(params.items())))) % (2**32))
        xyz = rng.uniform(0, 1, size=(n_points, 3))
        weights = np.array([(v - s.lower) / max(s.upper - s.lower, 1e-9) for s, v in zip(specs, params.values())])
        influence = float(np.mean(weights)) if len(weights) else 0.5
        severity = (
            0.4 * xyz[:, 0]
            + 0.3 * (1 - xyz[:, 1])
            + 0.3 * np.sin(2 * np.pi * xyz[:, 2])
            + influence
        )
        severity = (severity - severity.min()) / max(severity.max() - severity.min(), 1e-9)
        return np.column_stack([xyz, severity])

    def predict_metrics(self, params: Dict[str, float], specs: List[ParameterSpec]) -> Dict[str, float]:
        t, curve = self.predict_curve(params, specs)
        peak_idx = int(np.argmax(curve))
        t_peak = float(t[peak_idx])
        tmax = float(curve[peak_idx])

        # Simple cooling-rate proxy after the peak
        tail_start = peak_idx
        tail_end = min(len(t) - 1, peak_idx + 300)
        dt = max(t[tail_end] - t[tail_start], 1e-9)
        cooling_rate = float((curve[tail_start] - curve[tail_end]) / dt)

        param_values = np.array(list(params.values()), dtype=float)
        spread = float(np.std(param_values)) if len(param_values) else 0.0
        safety_score = float(max(0.0, 100 - 0.32 * tmax + 8.5 * cooling_rate - 3.5 * spread))
        mass_proxy = float(np.mean(param_values) * 1.3)

        return {
            "Tmax_peak": round(tmax, 3),
            "t_peak": round(t_peak, 3),
            "cooling_rate": round(cooling_rate, 5),
            "safety_score": round(safety_score, 3),
            "mass_proxy": round(mass_proxy, 3),
        }


# ============================================================
# Rule engine
# ============================================================
class RuleEngine:
    def __init__(self, rules: List[RuleSpec]):
        self.rules = rules

    def evaluate(self, metrics: Dict[str, float]) -> List[Dict[str, str]]:
        results = []
        for rule in self.rules:
            value = metrics.get(rule.metric, None)
            if value is None:
                results.append(
                    {
                        "metric": rule.metric,
                        "status": "UNKNOWN",
                        "detail": f"Metric not found: {rule.metric}",
                    }
                )
                continue

            status = self._judge(value, rule.operator, rule.threshold)
            results.append(
                {
                    "metric": rule.metric,
                    "status": status,
                    "detail": f"{rule.label}: {value} {rule.operator} {rule.threshold}",
                }
            )
        return results

    @staticmethod
    def _judge(value: float, op: str, threshold: float) -> str:
        if op == "<=":
            return "PASS" if value <= threshold else "FAIL"
        if op == "<":
            return "PASS" if value < threshold else "FAIL"
        if op == ">=":
            return "PASS" if value >= threshold else "FAIL"
        if op == ">":
            return "PASS" if value > threshold else "FAIL"
        if op == "==":
            return "PASS" if value == threshold else "FAIL"
        return "UNKNOWN"


# ============================================================
# Optimization engine (prototype)
# ============================================================
class OptimizationEngine:
    def __init__(self, surrogate: SurrogateEngine, specs: List[ParameterSpec]):
        self.surrogate = surrogate
        self.specs = specs

    def sample_random_design(self, fixed_params: Optional[Dict[str, float]] = None) -> Dict[str, float]:
        fixed_params = fixed_params or {}
        params = {}

        for s in self.specs:
            if s.name in fixed_params:
                params[s.name] = fixed_params[s.name]
            else:
                params[s.name] = round(random.uniform(s.lower, s.upper), 4)

        return params

    def optimize(
        self,
        n_samples: int,
        objective_weights: Dict[str, float],
        constraints: Optional[Dict[str, Tuple[str, float]]] = None,
        fixed_params: Optional[Dict[str, float]] = None,
    ) -> List[Tuple[float, Dict[str, float], Dict[str, float]]]:
        results = []
        start = time.time()

        for _ in range(n_samples):
            params = self.sample_random_design(fixed_params=fixed_params)
            metrics = self.surrogate.predict_metrics(params, self.specs)

            if not self._check_constraints(metrics, constraints or {}):
                continue

            score = self._score(metrics, objective_weights)
            results.append((score, params, metrics))

        results.sort(key=lambda x: x[0], reverse=True)
        elapsed = time.time() - start
        print(f"Optimization done in {elapsed:.2f}s / feasible results = {len(results)}")
        return results[:30]

    @staticmethod
    def _check_constraints(metrics: Dict[str, float], constraints: Dict[str, Tuple[str, float]]) -> bool:
        for key, (op, threshold) in constraints.items():
            value = metrics.get(key)
            if value is None:
                return False
            if op == "<=" and not (value <= threshold):
                return False
            if op == "<" and not (value < threshold):
                return False
            if op == ">=" and not (value >= threshold):
                return False
            if op == ">" and not (value > threshold):
                return False
        return True

    @staticmethod
    def _score(metrics: Dict[str, float], weights: Dict[str, float]) -> float:
        score = 0.0
        for k, w in weights.items():
            score += w * float(metrics.get(k, 0.0))
        return score


