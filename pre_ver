            textvariable=self.fixed_count_var,
            width=10,
            state="readonly",
            values=list(range(0, max_fixed + 1)),
        )
        self.fixed_count_combo.pack(side="left")
        self.fixed_count_combo.bind("<<ComboboxSelected>>", lambda e: self.update_fixed_param_selectors())

        # ---------------------------
        # Dynamic fixed variable selectors area
        # ---------------------------
        self.fixed_param_container = ttk.LabelFrame(control, text="고정 변수 항목 선택", padding=8)
        self.fixed_param_container.pack(fill="x", pady=(6, 8))

        self.update_fixed_param_selectors()

        self.opt_weight_vars = {}
        defaults = {
            "Tmax_peak": -1.0,
            "cooling_rate": 120.0,
            "safety_score": 1.5,
            "mass_proxy": -0.5,
        }
        for metric, default in defaults.items():
            row = ttk.Frame(control)
            row.pack(fill="x", pady=2)
            ttk.Label(row, text=f"Weight: {metric}", width=18).pack(side="left")
            var = tk.DoubleVar(value=default)
            self.opt_weight_vars[metric] = var
            ttk.Entry(row, textvariable=var, width=12).pack(side="left")

        constraint_frame = ttk.LabelFrame(control, text="Prototype Constraints", padding=8)
        constraint_frame.pack(fill="x", pady=(8, 0))
        self.constraint_tmax_var = tk.DoubleVar(value=180.0)
        self.constraint_safety_var = tk.DoubleVar(value=45.0)

        rowc1 = ttk.Frame(constraint_frame)
        rowc1.pack(fill="x", pady=2)
        ttk.Label(rowc1, text="Tmax_peak <=", width=18).pack(side="left")
        ttk.Entry(rowc1, textvariable=self.constraint_tmax_var, width=12).pack(side="left")

        rowc2 = ttk.Frame(constraint_frame)
        rowc2.pack(fill="x", pady=2)
        ttk.Label(rowc2, text="safety_score >=", width=18).pack(side="left")
        ttk.Entry(rowc2, textvariable=self.constraint_safety_var, width=12).pack(side="left")

        ttk.Button(control, text="Run Optimization", command=self.run_optimization).pack(anchor="w", pady=(10, 0))

        result_frame = ttk.LabelFrame(outer, text="Optimization Results", padding=8)
        result_frame.pack(fill="both", expand=True, pady=(8, 0))

        self.opt_tree = ttk.Treeview(
            result_frame,
            columns=("rank", "score", "Tmax_peak", "cooling_rate", "safety_score", "mass_proxy", "name"),
            show="headings",
            height=14,
        )
        for col, width in [
            ("rank", 60),
            ("score", 100),
            ("Tmax_peak", 100),
            ("cooling_rate", 110),
            ("safety_score", 110),
            ("mass_proxy", 100),
            ("name", 160),
        ]:
            self.opt_tree.heading(col, text=col)
            self.opt_tree.column(col, width=width, anchor="center")
        self.opt_tree.pack(fill="both", expand=True)
        self.opt_tree.bind("<Double-1>", self.load_selected_optimized_design)

    def _build_present_tab(self, parent):
        outer = ttk.Frame(parent, padding=8)
        outer.pack(fill="both", expand=True)

        btn_row = ttk.Frame(outer)
        btn_row.pack(fill="x", pady=(0, 8))
        ttk.Button(btn_row, text="Generate Summary", command=self.update_presentation_summary).pack(side="left")
        ttk.Button(btn_row, text="Copy Summary", command=self.copy_presentation_text).pack(side="left", padx=6)

        self.presentation_text = tk.Text(outer, wrap="word", font=("Malgun Gothic", 11))
        self.presentation_text.pack(fill="both", expand=True)

    # --------------------------------------------------------
    # State helpers
    # --------------------------------------------------------
    def _bind_default_values(self):
        for spec in self.parameter_specs:
            self.param_vars[spec.name].set(spec.default)

    def _on_param_change(self):
        # Lightweight hook. Avoid recomputing at every mouse move if needed later.
        pass

    def collect_current_parameters(self) -> Dict[str, float]:
        params = {}
        for spec in self.parameter_specs:
            try:
                value = float(self.param_vars[spec.name].get())
            except Exception:
                value = spec.default
            value = min(max(value, spec.lower), spec.upper)
            params[spec.name] = value
            self.param_vars[spec.name].set(value)
        return params

    def build_current_design(self) -> DesignCase:
        params = self.collect_current_parameters()
        name = self.meta_vars["design_name"].get().strip() or "Unnamed_Design"
        meta = {
            "Author": self.meta_vars["Author"].get().strip(),
            "Scenario": self.meta_vars["Scenario"].get().strip(),
            "Version": self.meta_vars["Version"].get().strip(),
        }
        metrics = self.surrogate.predict_metrics(params, self.parameter_specs)
        judgment = self.rule_engine.evaluate(metrics)
        return DesignCase(name=name, parameters=params, meta=meta, predicted_metrics=metrics, judgment=judgment)

    # --------------------------------------------------------
    # Core actions
    # --------------------------------------------------------
    def run_prediction(self):
        self.current_design = self.build_current_design()
        self.update_prediction_views()
        self.update_presentation_summary()

    def update_prediction_views(self):
        if not self.current_design:
            return

        params = self.current_design.parameters
        metrics = self.current_design.predicted_metrics
        t, curve = self.surrogate.predict_curve(params, self.parameter_specs)
        field = self.surrogate.predict_field_points(params, self.parameter_specs)

        self.ax_curve.clear()
        self.ax_curve.plot(t, curve, linewidth=1.2)
        self.ax_curve.set_title(f"Predicted Maximum Temperature vs Time - {self.current_design.name}")
        self.ax_curve.set_xlabel("Time")
        self.ax_curve.set_ylabel("Temperature")
        self.ax_curve.relim()
        self.ax_curve.autoscale(enable=True, axis="both", tight=False)
        self.ax_curve.grid(True, alpha=0.25)
        self.canvas_curve.draw()

        self.ax_field.clear()
        self.ax_field.scatter(field[:, 0], field[:, 1], field[:, 2], c=field[:, 3], s=18)
        self.ax_field.set_xlabel("X")
        self.ax_field.set_ylabel("Y")
        self.ax_field.set_zlabel("Z")
        self.ax_field.set_title("Representative XYZ Severity Points")
        self.canvas_field.draw()

        for k, v in metrics.items():
            if k in self.metric_vars:
                self.metric_vars[k].set(str(v))

        for item in self.judgement_tree.get_children():
            self.judgement_tree.delete(item)
        for row in self.current_design.judgment:
            self.judgement_tree.insert("", "end", values=(row["metric"], row["status"], row["detail"]))

    def add_current_to_compare(self):
        if not self.current_design:
            self.run_prediction()
        if not self.current_design:
            return

        if len(self.compare_basket) >= MAX_COMPARE_ITEMS:
            messagebox.showwarning("Comparison Basket", f"Maximum {MAX_COMPARE_ITEMS} designs can be stored.")
            return

        copied = DesignCase(
            name=self.current_design.name,
            parameters=dict(self.current_design.parameters),
            meta=dict(self.current_design.meta),
            predicted_metrics=dict(self.current_design.predicted_metrics),
            judgment=list(self.current_design.judgment),
        )
        self.compare_basket.append(copied)
        self.refresh_compare_table()
        self.refresh_compare_plot()
        self.notebook.select(self.tab_compare)

    def refresh_compare_table(self):
        for item in self.compare_tree.get_children():
            self.compare_tree.delete(item)

        for idx, design in enumerate(self.compare_basket, start=1):
            m = design.predicted_metrics
            self.compare_tree.insert(
                "",
                "end",
                values=(
                    idx,
                    design.name,
                    m.get("Tmax_peak", "-"),
                    m.get("t_peak", "-"),
                    m.get("cooling_rate", "-"),
                    m.get("safety_score", "-"),
                    m.get("mass_proxy", "-"),
                )
            )

    def refresh_compare_plot(self):
        self.ax_compare.clear()
        self.ax_compare.set_title("Comparison: Temperature Curves")
        self.ax_compare.set_xlabel("Time")
        self.ax_compare.set_ylabel("Temperature")

        for design in self.compare_basket:
            t, curve = self.surrogate.predict_curve(design.parameters, self.parameter_specs)
            self.ax_compare.plot(t, curve, linewidth=1.1, label=design.name)

        if self.compare_basket:
            self.ax_compare.legend(loc="best")
        self.ax_compare.grid(True, alpha=0.25)
        self.ax_compare.relim()
        self.ax_compare.autoscale(enable=True, axis="both", tight=False)
        self.canvas_compare.draw()

    def remove_selected_compare(self):
        selected = self.compare_tree.selection()
        if not selected:
            return
        idx = self.compare_tree.index(selected[0])
        if 0 <= idx < len(self.compare_basket):
            del self.compare_basket[idx]
        self.refresh_compare_table()
        self.refresh_compare_plot()

    def clear_compare(self):
        self.compare_basket = []
        self.refresh_compare_table()
        self.refresh_compare_plot()

    def run_optimization(self):
        try:
            n_samples = int(self.opt_samples_var.get())
        except Exception:
            n_samples = 300
        n_samples = max(20, min(20000, n_samples))
        self.opt_samples_var.set(n_samples)

        weights = {k: float(v.get()) for k, v in self.opt_weight_vars.items()}
        constraints = {
            "Tmax_peak": ("<=", float(self.constraint_tmax_var.get())),
            "safety_score": (">=", float(self.constraint_safety_var.get())),
        }

        fixed_params = self.get_fixed_params_for_optimization()

        results = self.optimizer.optimize(
            n_samples=n_samples,
            objective_weights=weights,
            constraints=constraints,
            fixed_params=fixed_params,
        )

        for item in self.opt_tree.get_children():
            self.opt_tree.delete(item)

        self.optimized_design_cache = []
        for rank, (score, params, metrics) in enumerate(results, start=1):
            name = f"Opt_{rank:02d}"
            self.optimized_design_cache.append((name, params, metrics, score))
            self.opt_tree.insert(
                "",
                "end",
                values=(
                    rank,
                    round(score, 4),
                    metrics.get("Tmax_peak", "-"),
                    metrics.get("cooling_rate", "-"),
                    metrics.get("safety_score", "-"),
                    metrics.get("mass_proxy", "-"),
                    name,
                )
            )

        self.notebook.select(self.tab_opt)

    def load_selected_optimized_design(self, event=None):
        selected = self.opt_tree.selection()
        if not selected:
            return
        idx = self.opt_tree.index(selected[0])
        if not hasattr(self, "optimized_design_cache"):
            return
        if idx >= len(self.optimized_design_cache):
            return

        name, params, metrics, score = self.optimized_design_cache[idx]
        for spec in self.parameter_specs:
            if spec.name in params:
                self.param_vars[spec.name].set(params[spec.name])
        self.meta_vars["design_name"].set(name)
        self.meta_vars["Scenario"].set(f"Optimization score={score:.3f}")
        self.run_prediction()
        self.notebook.select(self.tab_prediction)

    def update_presentation_summary(self):
        if not self.current_design:
            return
        d = self.current_design
        metrics = d.predicted_metrics
        passed = sum(1 for j in d.judgment if j["status"] == "PASS")
        failed = sum(1 for j in d.judgment if j["status"] == "FAIL")

        top_params = sorted(d.parameters.items(), key=lambda x: abs(x[1]), reverse=True)[:5]
        top_params_text = "\n".join([f"- {k}: {v}" for k, v in top_params])

        summary = f"""[Design Summary]\n\nDesign name: {d.name}\nAuthor: {d.meta.get('Author', '')}\nScenario: {d.meta.get('Scenario', '')}\nVersion: {d.meta.get('Version', '')}\n\n[Key Metrics]\n- Tmax_peak: {metrics.get('Tmax_peak')}\n- t_peak: {metrics.get('t_peak')}\n- cooling_rate: {metrics.get('cooling_rate')}\n- safety_score: {metrics.get('safety_score')}\n- mass_proxy: {metrics.get('mass_proxy')}\n\n[Judgement]\n- PASS count: {passed}\n- FAIL count: {failed}\n\n[Top Parameters Snapshot]\n{top_params_text}\n\n[Interpretation]\n- This summary is generated from the current surrogate placeholder model.\n- Maximum-temperature time series is displayed with auto-scale.\n- Spatial result currently uses representative XYZ severity points, not true cell-mapped coordinates.\n- Comparison basket can store up to 5 designs.\n- Optimization tab uses random-search based multi-objective screening as a prototype.\n\n[Next Integration Targets]\n1. Connect real trained surrogate model.\n2. Replace placeholder rule limits with engineering criteria.\n3. Add real simulation import and result database.\n4. Add true design comparison report export.\n"""
        self.presentation_text.delete("1.0", tk.END)
        self.presentation_text.insert("1.0", summary)

    def copy_presentation_text(self):
        text = self.presentation_text.get("1.0", tk.END).strip()
        self.clipboard_clear()
        self.clipboard_append(text)
        messagebox.showinfo("Copied", "Presentation summary copied to clipboard.")

    def reset_defaults(self):
        for spec in self.parameter_specs:
            self.param_vars[spec.name].set(spec.default)
        self.meta_vars["design_name"].set("Design_001")
        self.meta_vars["Author"].set("")
        self.meta_vars["Scenario"].set("")
        self.meta_vars["Version"].set("")
        self.run_prediction()

    # --------------------------------------------------------
    # File I/O
    # --------------------------------------------------------
    def serialize_project(self) -> Dict:
        return {
            "parameter_specs": [asdict(s) for s in self.parameter_specs],
            "rule_specs": [asdict(r) for r in self.rule_specs],
            "current_design": asdict(self.current_design) if self.current_design else None,
            "compare_basket": [asdict(d) for d in self.compare_basket],
        }

    def deserialize_project(self, data: Dict):
        current = data.get("current_design")
        compare = data.get("compare_basket", [])

        if current:
            self.meta_vars["design_name"].set(current.get("name", "Design_001"))
            for k, v in current.get("meta", {}).items():
                if k in self.meta_vars:
                    self.meta_vars[k].set(v)
            for spec in self.parameter_specs:
                if spec.name in current.get("parameters", {}):
                    self.param_vars[spec.name].set(current["parameters"][spec.name])

        self.compare_basket = [
            DesignCase(
                name=item["name"],
                parameters=item["parameters"],
                meta=item.get("meta", {}),
                predicted_metrics=item.get("predicted_metrics", {}),
                judgment=item.get("judgment", []),
            )
            for item in compare
        ]
        self.run_prediction()
        self.refresh_compare_table()
        self.refresh_compare_plot()

    def new_project(self):
        self.project_path = None
        self.compare_basket = []
        self.reset_defaults()
        self.refresh_compare_table()
        self.refresh_compare_plot()

    def open_project(self):
        path = filedialog.askopenfilename(
            title="Open project",
            filetypes=[("JSON files", "*.json"), ("All files", "*.*")]
        )
        if not path:
            return
        try:
            with open(path, "r", encoding="utf-8") as f:
                data = json.load(f)
            self.deserialize_project(data)
            self.project_path = Path(path)
            messagebox.showinfo("Open", f"Project loaded:\n{path}")
        except Exception as e:
            messagebox.showerror("Error", f"Failed to open project.\n\n{e}")

    def save_project(self):
        if self.project_path is None:
            self.save_project_as()
            return
        try:
            with open(self.project_path, "w", encoding="utf-8") as f:
                json.dump(self.serialize_project(), f, ensure_ascii=False, indent=2)
            messagebox.showinfo("Save", f"Project saved:\n{self.project_path}")
        except Exception as e:
            messagebox.showerror("Error", f"Failed to save project.\n\n{e}")

    def save_project_as(self):
        path = filedialog.asksaveasfilename(
            title="Save project as",
            defaultextension=".json",
            filetypes=[("JSON files", "*.json"), ("All files", "*.*")]
        )
        if not path:
            return
        self.project_path = Path(path)
        self.save_project()

    def export_current_design(self):
        if not self.current_design:
            self.run_prediction()
        if not self.current_design:
            return

        path = filedialog.asksaveasfilename(
            title="Export current design",
            defaultextension=".json",
            filetypes=[("JSON files", "*.json"), ("All files", "*.*")]
        )
        if not path:
            return

        try:
            with open(path, "w", encoding="utf-8") as f:
                json.dump(asdict(self.current_design), f, ensure_ascii=False, indent=2)
            messagebox.showinfo("Export", f"Current design exported:\n{path}")
        except Exception as e:
            messagebox.showerror("Error", f"Failed to export current design.\n\n{e}")


def main():
    app = DesignApp()
    app.mainloop()


if __name__ == "__main__":
