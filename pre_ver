    def update_fixed_param_selectors(self):
        for widget in self.fixed_param_container.winfo_children():
            widget.destroy()

        self.fixed_param_name_vars = []
        self.fixed_param_rows = []
        self.fixed_param_boxes = []

        try:
            count = int(self.fixed_count_var.get())
        except Exception:
            count = 0

        param_names = [spec.name for spec in self.parameter_specs]

        for i in range(count):
            row = ttk.Frame(self.fixed_param_container)
            row.pack(fill="x", pady=2)

            ttk.Label(row, text=f"고정 변수 {i+1}", width=18).pack(side="left")

            var = tk.StringVar()
            combo = ttk.Combobox(
                row,
                textvariable=var,
                width=24,
                state="readonly",
                values=param_names,
            )
            combo.pack(side="left", fill="x", expand=True)

            if i < len(param_names):
                var.set(param_names[i])

            combo.bind("<<ComboboxSelected>>", lambda e: self._refresh_fixed_param_options())

            self.fixed_param_name_vars.append(var)
            self.fixed_param_rows.append(row)
            self.fixed_param_boxes.append(combo)

        self._refresh_fixed_param_options()

    def _refresh_fixed_param_options(self):
        selected_names = [var.get() for var in self.fixed_param_name_vars if var.get()]

        all_names = [spec.name for spec in self.parameter_specs]

        for idx, combo in enumerate(self.fixed_param_boxes):
            current_value = self.fixed_param_name_vars[idx].get()

            allowed = []
            for name in all_names:
                if name == current_value or name not in [n for j, n in enumerate(selected_names) if j != idx]:
                    allowed.append(name)

            combo["values"] = allowed

            if current_value not in allowed:
                self.fixed_param_name_vars[idx].set("")
                
    def get_fixed_params_for_optimization(self) -> Dict[str, float]:
        fixed_params = {}
        current_params = self.collect_current_parameters()

        for var in self.fixed_param_name_vars:
            name = var.get().strip()
            if name and name in current_params:
                fixed_params[name] = current_params[name]

        return fixed_params

